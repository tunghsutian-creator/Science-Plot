#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO="${SCIPLOT_REPO:-$(cd "$SCRIPT_DIR/../.." && pwd)}"
PYTHON="${SCIPLOT_PYTHON:-$REPO/.venv/bin/python}"

if [[ ! -x "$PYTHON" ]]; then
  PYTHON="python3"
fi

export MPLCONFIGDIR="${MPLCONFIGDIR:-${TMPDIR:-/tmp}/sciplot-mpl}"
mkdir -p "$MPLCONFIGDIR"

cd "$REPO"
exec "$PYTHON" -m sciplot_core.cli "$@"
