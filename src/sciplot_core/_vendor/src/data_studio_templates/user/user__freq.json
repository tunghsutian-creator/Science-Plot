      "column_name": "Angular Frequency",
      "column_index": null,
      "row_label_contains": null,
      "cell_value_contains": [],
      "unit_hint": "rad/s",
      "optional": false
    },
    {
      "id": "y_storage_modulus",
      "role": "curve_y",
      "label": "Storage Modulus",
      "sheet_name": "Sheet1",
      "block_id": "Sheet1::segment1",
      "column_name": "Storage Modulus",
      "column_index": null,
      "row_label_contains": null,
      "cell_value_contains": [],
      "unit_hint": "Pa",
      "optional": false
    },
    {
      "id": "y_loss_modulus",
      "role": "curve_y",
      "label": "Loss Modulus",
      "sheet_name": "Sheet1",
      "block_id": "Sheet1::segment1",
      "column_name": "Loss Modulus",
      "column_index": null,
      "row_label_contains": null,
      "cell_value_contains": [],
      "unit_hint": "Pa",
      "optional": false
    },
    {
      "id": "y_complex_viscosity",
      "role": "curve_y",
      "label": "Complex Viscosity",
      "sheet_name": "Sheet1",
      "block_id": "Sheet1::segment1",
      "column_name": "Complex Viscosity",
      "column_index": null,
      "row_label_contains": null,
      "cell_value_contains": [],
      "unit_hint": "mPa·s",
      "optional": false
    },
    {
      "id": "y_loss_factor",
      "role": "curve_y",
      "label": "Loss Factor",
      "sheet_name": "Sheet1",
      "block_id": "Sheet1::segment1",
      "column_name": "Loss Factor",
      "column_index": null,
      "row_label_contains": null,
      "cell_value_contains": [],
      "unit_hint": "1",
      "optional": false
    }
