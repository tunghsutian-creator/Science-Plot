  "preferred_sheet_name": "Storage_Loss_Modulus",
  "output_kind": "curve_metrics",
  "comparison_enabled": false,
  "source_format": {
    "encoding": "utf-16",
    "delimiter": "\t",
    "sheet_name": "Sheet1"
  },
  "segment_policy": "series_per_segment",
  "segment_selectors": [
    {
      "id": "Sheet1::segment1",
      "label": "Frequency sweep 1 / Interval 1",
      "result_label": "Frequency sweep 1",
      "interval_index": 1,
      "header_row_index": 7,
      "unit_row_index": 9,
      "data_start_row_index": 10,
      "start_row": 7,
      "end_row": 25
    }
  ],
  "metadata": {
    "created_by": "data_studio_import_template_v2",
