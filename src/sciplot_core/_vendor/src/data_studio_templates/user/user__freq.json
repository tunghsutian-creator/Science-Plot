{
  "version": 2,
  "id": "user/freq",
  "label": "Freq",
  "family": "table_import",
  "builtin": false,
  "description": "Template created from E0.csv.",
  "file_types": [
    "csv",
    "txt",
    "tsv",
    "xls",
    "xlsx",
    "xlsm"
  ],
  "parse_strategy": "table_template_v2",
  "match_conditions": [
    {
      "sheet_name_contains": [
        "Sheet1"
