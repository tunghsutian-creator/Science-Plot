        "Angular Frequency",
        "Storage Modulus",
        "Loss Modulus"
      ],
      "field_kinds": [
        "curve_x",
        "curve_y"
      ],
      "minimum_score": 0.3
    }
  ],
  "field_bindings": [
    {
      "id": "x_angular_frequency",
      "role": "curve_x",
      "label": "Angular Frequency",
      "sheet_name": "Sheet1",
